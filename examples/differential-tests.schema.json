{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "formalspecc differential test vectors",
  "type": "object",
  "required": ["function", "cases"],
  "properties": {
    "function": {
      "type": "string"
    },
    "signature": {
      "type": "object",
      "required": ["return_type", "params"],
      "properties": {
        "return_type": { "type": "string" },
        "params": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        }
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["args", "expected"],
        "properties": {
          "name": { "type": "string" },
          "args": {
            "type": "array",
            "items": {}
          },
          "expected": {}
        }
      }
    }
  }
}
